# Production environment for the docker-compose deploy. Copy to deploy/.env on the
# droplet, fill in real values, then `docker compose --env-file deploy/.env -f
# deploy/compose.yaml up -d`. Never commit deploy/.env to git.

# ---- Public hostname ----
# The fully-qualified domain pointed at the droplet's IP via an A record. Caddy uses
# this to provision a TLS certificate from Let's Encrypt on first boot.
NEEDLR_DOMAIN=needlr.example.com
NEEDLR_TLS_EMAIL=ops@example.com

# ---- PostgreSQL ----
# These create the database on first start and authenticate the API to it. Pick a
# strong random password; rotate by editing here, recreating the postgres container,
# and restarting the api container.
POSTGRES_USER=needlr
POSTGRES_PASSWORD=replace-with-a-long-random-string
POSTGRES_DB=needlr

# ---- JWT signing ----
# Issuer + audience are public claims (the domain, typically). The signing key must be
# at least 32 random bytes; generate one with `openssl rand -base64 48`. Rotating
# invalidates all live tokens — clients are signed out and must re-login.
JWT_ISSUER=https://needlr.example.com
JWT_AUDIENCE=https://needlr.example.com
JWT_SIGNING_KEY=replace-with-openssl-rand-base64-48
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ---- Stripe (direct charge per ADR-005) ----
# Required for booking payment capture. Until these are filled in the api still boots
# but POST /api/bookings hard-fails the payment step. Use test-mode keys for staging,
# live-mode keys for production. The webhook secret comes from the Stripe Dashboard
# webhook page after pointing the endpoint at https://NEEDLR_DOMAIN/api/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_RETURN_URL=https://needlr.example.com/artist

# ---- Notifications ----
# Email via Resend; web-push via VAPID. Both are optional — the dispatcher logs and
# swallows per-channel failures, so leaving these empty merely disables that channel.
# Resend: create an API key at https://resend.com/api-keys and verify your sending
# domain (Resend → Domains) so NOTIFICATIONS_FROM_EMAIL passes DKIM/SPF.
# VAPID keys: generate with `npx web-push generate-vapid-keys` (one-time setup).
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=no-reply@needlr.example.com
NOTIFICATIONS_FROM_NAME=Needlr
VAPID_SUBJECT=mailto:ops@needlr.example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
