@page "/"
@inject INeedlrApi Api

<PageTitle>Needlr · Find a tattoo artist in Montréal</PageTitle>

<section class="needlr-discovery">
    <header class="needlr-filter-bar">
        <div class="needlr-pill-row">
            @* Boolean toggles render as on/off pills — visual consistency with the disclosure pills
               and a clearer affordance than a checkbox glued to a label. *@
            <button type="button"
                class="needlr-pill @(_verifiedOnly ? "active" : "")"
                @onclick="ToggleVerifiedAsync"
                title="Show only studios with a Verified health inspection">
                @(_verifiedOnly ? "✓ " : "")Verified
            </button>
            <button type="button"
                class="needlr-pill @(_walkInsOnly ? "active" : "")"
                @onclick="ToggleWalkInsAsync"
                title="Show only studios that accept walk-up customers">
                @(_walkInsOnly ? "✓ " : "")Walk-ins
            </button>

            @* Styles disclosure pill — opens a popover with the full chip grid. The pill carries
               the active count so the user knows the filter is engaged even when collapsed. *@
            <button type="button"
                class="needlr-pill needlr-pill-disclosure @(_selectedStyleIds.Count > 0 ? "active" : "")"
                @onclick="() => _stylePopoverOpen = !_stylePopoverOpen">
                Styles@(_selectedStyleIds.Count > 0 ? $" · {_selectedStyleIds.Count}" : "")
                <span class="needlr-pill-caret" aria-hidden="true">▾</span>
            </button>

            @* Availability disclosure pill — preset chips inside; "Custom" reveals the date inputs.
               Default Anytime means no filter; the page loads showing every bookable studio. *@
            <button type="button"
                class="needlr-pill needlr-pill-disclosure @(_availabilityPreset != AvailabilityPreset.Anytime ? "active" : "")"
                @onclick="() => _availabilityPopoverOpen = !_availabilityPopoverOpen">
                Available · @PresetLabel(_availabilityPreset)
                <span class="needlr-pill-caret" aria-hidden="true">▾</span>
            </button>

            <span class="needlr-filter-spacer"></span>

            <button type="button" class="needlr-pill needlr-pill-ghost"
                @onclick="() => _showList = !_showList">
                @(_showList ? "Hide list" : "Show list")
            </button>
        </div>

        @if (_stylePopoverOpen)
        {
            <div class="needlr-popover-backdrop" @onclick="CloseStylePopover"></div>
            <div class="needlr-popover needlr-popover-styles" @onclick:stopPropagation="true">
                <div class="needlr-popover-header">
                    <strong>Styles</strong>
                    @if (_selectedStyleIds.Count > 0)
                    {
                        <button type="button" class="needlr-link-button" @onclick="ClearStylesAsync">Clear</button>
                    }
                    <button type="button" class="needlr-link-button" @onclick="CloseStylePopover">Done</button>
                </div>
                @if (_styles is { Count: > 0 })
                {
                    <div class="needlr-chips">
                        @foreach (var style in _styles)
                        {
                            var active = _selectedStyleIds.Contains(style.Id);
                            <button type="button"
                                class="needlr-chip @(active ? "active" : "")"
                                @onclick="() => ToggleStyleAsync(style.Id)">
                                @style.Name
                            </button>
                        }
                    </div>
                }
                else
                {
                    <p class="needlr-aside">Style list unavailable.</p>
                }
            </div>
        }

        @if (_availabilityPopoverOpen)
        {
            <div class="needlr-popover-backdrop" @onclick="CloseAvailabilityPopover"></div>
            <div class="needlr-popover needlr-popover-availability" @onclick:stopPropagation="true">
                <div class="needlr-popover-header">
                    <strong>When are you looking?</strong>
                    <button type="button" class="needlr-link-button" @onclick="CloseAvailabilityPopover">Done</button>
                </div>
                <div class="needlr-preset-list">
                    @foreach (var preset in PresetOrder)
                    {
                        var active = preset == _availabilityPreset;
                        <button type="button"
                            class="needlr-preset @(active ? "active" : "")"
                            @onclick="() => SelectPresetAsync(preset)">
                            @PresetLabel(preset)
                            @if (PresetSubtitle(preset) is { } sub)
                            {
                                <small>@sub</small>
                            }
                        </button>
                    }
                </div>
                @if (_availabilityPreset == AvailabilityPreset.Custom)
                {
                    <div class="needlr-custom-range">
                        <label>
                            <span>From</span>
                            <input type="date" @bind="_availabilityFrom" @bind:after="ReloadAsync" />
                        </label>
                        <label>
                            <span>To</span>
                            <input type="date" @bind="_availabilityTo" @bind:after="ReloadAsync" />
                        </label>
                    </div>
                }
            </div>
        }
    </header>

    <div class="needlr-discovery-body">
        <div class="needlr-map-wrap">
            @* Greater Montréal pan box — South Shore + Laval inclusive. Min zoom keeps the
               city in view; max zoom reaches street level. Style URL falls through to
               OpenFreeMap Liberty inside mapInterop.js. *@
            <MapComponent
                OnBoundsChanged="HandleBoundsChangedAsync"
                OnPinClicked="HandlePinClickedAsync"
                Pins="_pins"
                MaxBounds="MontrealBounds"
                MinZoom="9"
                MaxZoom="18" />
        </div>

        @if (_showList || _selectedStudioId is not null)
        {
            <aside class="needlr-side-panel">
                @if (_selectedStudioId is { } sid)
                {
                    <button type="button" class="needlr-back" @onclick="() => _selectedStudioId = null">← Back to list</button>
                    <StudioDetailPanel StudioId="sid" IsVerifiedFromDiscovery="_selectedIsVerified" />
                }
                else if (_loading)
                {
                    <p>Searching…</p>
                }
                else if (_error is not null)
                {
                    <p class="needlr-error" role="alert">@_error</p>
                }
                else if (_results?.Items.Count > 0)
                {
                    <p class="needlr-result-count">@_results.TotalCount studio(s) in this area</p>
                    <ul class="needlr-result-list">
                        @foreach (var s in _results.Items)
                        {
                            <li>
                                <button type="button" class="needlr-result-row"
                                    @onclick="() => OpenStudio(s.Id, s.IsVerified)">
                                    <strong>@s.Name</strong>
                                    <span>@s.Address</span>
                                    <span class="needlr-meta">
                                        @s.ActiveArtistCount artist(s)
                                        @if (s.IsVerified) { <span class="needlr-badge verified small">Verified</span> }
                                        else if (s.HasSubmittedDocuments) { <span class="needlr-badge submitted small">Docs in review</span> }
                                    </span>
                                </button>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="needlr-aside">Pan the map or change filters to find studios.</p>
                }
            </aside>
        }
    </div>
</section>

@code {
    /// <summary>
    /// Availability presets shown inside the Available popover. Most discovery sessions don't
    /// have a hard date in mind — defaulting to <see cref="Anytime"/> means the page returns
    /// results without forcing the user to pick a window. Custom keeps the date pickers
    /// available for power users (e.g., trips, holiday weekends).
    /// </summary>
    private enum AvailabilityPreset { Anytime, ThisWeek, ThisMonth, NextThreeMonths, Custom }

    private static readonly AvailabilityPreset[] PresetOrder =
    [
        AvailabilityPreset.Anytime,
        AvailabilityPreset.ThisWeek,
        AvailabilityPreset.ThisMonth,
        AvailabilityPreset.NextThreeMonths,
        AvailabilityPreset.Custom
    ];

    /// <summary>
    /// Greater Montréal pan-restriction box. Generous enough to include South Shore
    /// (Longueuil/Brossard) and Laval; tight enough that camera drift can't escape the
    /// launch market. When we add a second market, this becomes per-market config.
    /// </summary>
    private static readonly MapComponent.MaxBoundsBox MontrealBounds = new(
        SouthLat: 45.30, WestLng: -74.00, NorthLat: 45.80, EastLng: -73.30);

    private bool _verifiedOnly = true;
    private bool _walkInsOnly;
    private AvailabilityPreset _availabilityPreset = AvailabilityPreset.Anytime;
    private DateTime? _availabilityFrom;
    private DateTime? _availabilityTo;
    private bool _showList = true;

    private bool _stylePopoverOpen;
    private bool _availabilityPopoverOpen;

    private MapComponent.MapBounds? _lastBounds;
    private DiscoveryPageResponse? _results;
    private IReadOnlyList<MapComponent.MapPin>? _pins;
    private bool _loading;
    private string? _error;

    private Guid? _selectedStudioId;
    private bool _selectedIsVerified;

    private IReadOnlyList<TattooStyleResponse>? _styles;
    private readonly HashSet<Guid> _selectedStyleIds = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _styles = await Api.ListCanonicalStylesAsync();
        }
        catch (NeedlrApiException)
        {
            _styles = null;
        }
    }

    private static string PresetLabel(AvailabilityPreset p) => p switch
    {
        AvailabilityPreset.Anytime => "Anytime",
        AvailabilityPreset.ThisWeek => "This week",
        AvailabilityPreset.ThisMonth => "This month",
        AvailabilityPreset.NextThreeMonths => "Next 3 months",
        AvailabilityPreset.Custom => "Custom",
        _ => "Anytime"
    };

    private static string? PresetSubtitle(AvailabilityPreset p) => p switch
    {
        AvailabilityPreset.Anytime => "Show every bookable studio",
        AvailabilityPreset.ThisWeek => "Today through 7 days out",
        AvailabilityPreset.ThisMonth => "Today through 30 days out",
        AvailabilityPreset.NextThreeMonths => "Today through 90 days out",
        AvailabilityPreset.Custom => "Pick exact dates",
        _ => null
    };

    private async Task SelectPresetAsync(AvailabilityPreset preset)
    {
        _availabilityPreset = preset;
        var today = DateTime.Today;
        switch (preset)
        {
            case AvailabilityPreset.Anytime:
                _availabilityFrom = null;
                _availabilityTo = null;
                break;
            case AvailabilityPreset.ThisWeek:
                _availabilityFrom = today;
                _availabilityTo = today.AddDays(7);
                break;
            case AvailabilityPreset.ThisMonth:
                _availabilityFrom = today;
                _availabilityTo = today.AddDays(30);
                break;
            case AvailabilityPreset.NextThreeMonths:
                _availabilityFrom = today;
                _availabilityTo = today.AddDays(90);
                break;
            case AvailabilityPreset.Custom:
                // Leave the existing dates in place so toggling Custom doesn't blow away
                // a half-typed range. If the user hasn't picked anything yet, both stay null
                // and the filter is a no-op until they enter values.
                break;
        }
        await ReloadAsync();
    }

    private async Task ToggleVerifiedAsync()
    {
        _verifiedOnly = !_verifiedOnly;
        await ReloadAsync();
    }

    private async Task ToggleWalkInsAsync()
    {
        _walkInsOnly = !_walkInsOnly;
        await ReloadAsync();
    }

    private async Task ToggleStyleAsync(Guid styleId)
    {
        if (!_selectedStyleIds.Add(styleId)) _selectedStyleIds.Remove(styleId);
        await ReloadAsync();
    }

    private async Task ClearStylesAsync()
    {
        _selectedStyleIds.Clear();
        await ReloadAsync();
    }

    private void CloseStylePopover() => _stylePopoverOpen = false;
    private void CloseAvailabilityPopover() => _availabilityPopoverOpen = false;

    private async Task HandleBoundsChangedAsync(MapComponent.MapBounds bounds)
    {
        _lastBounds = bounds;
        await ReloadAsync();
    }

    private void HandlePinClickedAsync(Guid studioId)
    {
        var match = _results?.Items.FirstOrDefault(s => s.Id == studioId);
        OpenStudio(studioId, match?.IsVerified ?? false);
    }

    private void OpenStudio(Guid id, bool isVerified)
    {
        _selectedStudioId = id;
        _selectedIsVerified = isVerified;
    }

    private async Task ReloadAsync()
    {
        if (_lastBounds is null) return;

        _loading = true;
        _error = null;
        try
        {
            var args = new DiscoverySearchArgs(
                SouthLat: _lastBounds.SouthLat,
                WestLng: _lastBounds.WestLng,
                NorthLat: _lastBounds.NorthLat,
                EastLng: _lastBounds.EastLng,
                CenterLat: _lastBounds.CenterLat,
                CenterLng: _lastBounds.CenterLng,
                VerifiedOnly: _verifiedOnly,
                AcceptsWalkInsOnly: _walkInsOnly,
                StyleIds: _selectedStyleIds.Count > 0 ? _selectedStyleIds.ToList() : null,
                AvailabilityFrom: _availabilityFrom is { } f ? DateOnly.FromDateTime(f) : null,
                AvailabilityTo: _availabilityTo is { } t ? DateOnly.FromDateTime(t) : null,
                Page: 1,
                PageSize: 50);
            _results = await Api.SearchStudiosAsync(args);
            _pins = _results.Items
                .Select(s => new MapComponent.MapPin(
                    s.Id, s.Name, s.Location.Latitude, s.Location.Longitude, s.IsVerified))
                .ToList();
        }
        catch (NeedlrApiException ex)
        {
            _error = ex.Message;
            _pins = null;
        }
        finally
        {
            _loading = false;
        }
    }
}
