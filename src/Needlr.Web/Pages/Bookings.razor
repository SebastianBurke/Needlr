@page "/bookings"
@inject INeedlrApi Api
@inject AuthState Auth

<PageTitle>Bookings · Needlr</PageTitle>

<RequireAuth>
<section class="needlr-bookings-dashboard">
    <header class="needlr-dashboard-header">
        <h1>@(_isArtist ? "Bookings" : "My bookings")</h1>
    </header>

    @if (_loading)
    {
        <p>Loading…</p>
    }
    else if (_error is not null)
    {
        <p class="needlr-error" role="alert">@_error</p>
    }
    else
    {
        @* Action-required is the lead-in: artists see pending requests with inline accept /
           decline / request-info; customers see bookings the artist has stuck on info. The
           section only renders empty-state copy when there's nothing to act on, so a clean
           inbox isn't noisy. *@
        @if (_isArtist)
        {
            <BookingGroup
                Title="Awaiting your response"
                Items="@_action"
                Empty="No new requests."
                Show="BookingGroup.CounterpartyView.Customer"
                RowExtra="ArtistRowExtra" />
        }
        else
        {
            <BookingGroup
                Title="Action needed"
                Items="@_action"
                Empty="Nothing needs your attention."
                Show="BookingGroup.CounterpartyView.Artist"
                RowExtra="CustomerRowExtra" />
        }

        <BookingGroup
            Title="Upcoming"
            Items="@_upcoming"
            Empty="No upcoming sessions."
            Show="@CounterpartyForRole" />

        <BookingGroup
            Title="Past"
            Items="@_past"
            Empty="No past bookings yet."
            Show="@CounterpartyForRole"
            CollapsibleAfter="5" />
    }
</section>
</RequireAuth>

@code {
    private bool _isArtist;
    private bool _loading;
    private string? _error;

    private IReadOnlyList<BookingSummaryResponse>? _action;
    private IReadOnlyList<BookingSummaryResponse>? _upcoming;
    private IReadOnlyList<BookingSummaryResponse>? _past;

    private BookingGroup.CounterpartyView CounterpartyForRole =>
        _isArtist ? BookingGroup.CounterpartyView.Customer : BookingGroup.CounterpartyView.Artist;

    /// <summary>Inline-action fragment for the artist's pending-requests rows.</summary>
    private RenderFragment<BookingSummaryResponse> ArtistRowExtra => booking =>
        @<ArtistInboxRowActions Booking="booking" OnChanged="ReloadAsync" />;

    /// <summary>
    /// Customer-side action rows currently surface only AwaitingCustomerInfo bookings —
    /// the response form on the detail page is too wide to inline cleanly, so we just
    /// give the customer a clear "Respond →" affordance that lands them on the form.
    /// </summary>
    private RenderFragment<BookingSummaryResponse> CustomerRowExtra => booking =>
        @<div class="needlr-row-extra-actions">
            <a class="needlr-btn primary" href="@($"bookings/{booking.Id}")">Respond →</a>
        </div>;

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureHydratedAsync();
        if (!Auth.IsAuthenticated) return;
        _isArtist = Auth.Role == "Artist";
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        if (!Auth.IsAuthenticated) return;
        _loading = true;
        _error = null;
        try
        {
            // Three independent fetches per role; fan out so the page paints faster. The
            // Action / Upcoming / Past split mirrors how the artist's old /bookings/inbox
            // grouped things — same shape, now applied to both roles.
            var actionStatus = _isArtist ? "Requested" : "AwaitingCustomerInfo";

            var actionTask = ListAsync(actionStatus);
            var upcomingTask = ListAsync("Confirmed");
            var pastTask = ListAsync("Completed");

            var action = await actionTask;
            var upcoming = await upcomingTask;
            var past = await pastTask;

            _action = action;
            // Sort upcoming by session-date proximity (soonest first); past by completion
            // recency. Both lists already paginate at the API; for v1 the page sizes (50)
            // are large enough that client-side sort produces the right order.
            _upcoming = upcoming.OrderBy(b => b.ConfirmedSessionDate ?? DateTime.MaxValue).ToList();
            _past = past.OrderByDescending(b => b.ConfirmedSessionDate ?? b.RequestedAt).ToList();
        }
        catch (NeedlrApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<IReadOnlyList<BookingSummaryResponse>> ListAsync(string status)
    {
        var page = _isArtist
            ? await Api.ListMyBookingsAsArtistAsync(status, 1, 50)
            : await Api.ListMyBookingsAsCustomerAsync(status, 1, 50);
        return page.Items;
    }
}
