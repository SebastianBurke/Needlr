@page "/bookings/inbox"
@inject INeedlrApi Api
@inject AuthState Auth

<PageTitle>Inbox · Needlr</PageTitle>

<RequireAuth RequiredRole="Artist">
<section class="needlr-bookings-dashboard">
        <h1>Booking inbox</h1>
        <p class="needlr-sub">Triage requests, track upcoming sessions, and review history.</p>

        @if (_loading)
        {
            <p>Loading…</p>
        }
        else if (_error is not null)
        {
            <p class="needlr-error" role="alert">@_error</p>
        }
        else
        {
            <BookingGroup Title="Awaiting your response" Items="@_requested" Empty="No new requests." />
            <BookingGroup Title="Upcoming" Items="@_upcoming" Empty="No upcoming sessions." />
            <BookingGroup Title="History" Items="@_history" Empty="No completed bookings yet." />
        }
</section>
</RequireAuth>

@code {
    private bool _loading;
    private string? _error;
    private IReadOnlyList<BookingSummaryResponse>? _requested;
    private IReadOnlyList<BookingSummaryResponse>? _upcoming;
    private IReadOnlyList<BookingSummaryResponse>? _history;

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureHydratedAsync();
        if (!Auth.IsAuthenticated || Auth.Role != "Artist") return;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            // Three independent fetches; fan out so the page paints faster.
            var requestedTask = Api.ListMyBookingsAsArtistAsync("Requested", 1, 50);
            var confirmedTask = Api.ListMyBookingsAsArtistAsync("Confirmed", 1, 50);
            var completedTask = Api.ListMyBookingsAsArtistAsync("Completed", 1, 50);
            var requested = await requestedTask;
            var confirmed = await confirmedTask;
            var completed = await completedTask;
            _requested = requested.Items;
            _upcoming = confirmed.Items;
            _history = completed.Items;
        }
        catch (NeedlrApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
