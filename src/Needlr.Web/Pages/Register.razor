@page "/register"
@inject NavigationManager Nav

<PageTitle>Join Needlr</PageTitle>

<section class="needlr-auth">
    <h1>Join Needlr</h1>
    <p class="needlr-sub">Pick the path that matches you.</p>

    <div class="needlr-role-picker">
        <a href="@($"register/customer{ReturnQuery}")" class="needlr-role-card">
            <h3>I'm here to get tattooed</h3>
            <p>Find licensed Montréal artists and book a session.</p>
        </a>
        <a href="register/artist" class="needlr-role-card">
            <h3>I'm a tattoo artist</h3>
            <p>Set up your profile, portfolio, and booking flow.</p>
        </a>
    </div>

    <p class="needlr-aside">
        Already have an account? <a href="@($"login{ReturnQuery}")">Sign in</a>.
    </p>
</section>

@code {
    // Pass-through ?return= so the customer-flow lands the user back on the page they were
    // browsing (e.g., the artist profile they wanted to book). Artist registration always
    // lands on /artist regardless — return URLs don't make sense there.
    private string ReturnQuery
    {
        get
        {
            var uri = new Uri(Nav.Uri);
            var ret = System.Web.HttpUtility.ParseQueryString(uri.Query)["return"];
            return string.IsNullOrWhiteSpace(ret) ? "" : $"?return={Uri.EscapeDataString(ret)}";
        }
    }
}
