@page "/artist/profile"
@inject INeedlrApi Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Account · Needlr</PageTitle>

<RequireAuth RequiredRole="Artist">
<section class="needlr-profile-tools">
        <a class="needlr-link-back" href="artist">← Artist tools</a>
        <h1>Account</h1>
        <p class="needlr-sub">Signed in as <strong>@Auth.Email</strong> · Artist</p>

        <section class="needlr-card">
            <h2>Bookings</h2>
            <label class="needlr-toggle-row">
                <input type="checkbox" @bind="_accepting" />
                <span>Accepting new booking requests</span>
            </label>
            <p class="needlr-aside">
                When off, your profile stays visible on Needlr but new customers see a
                "not taking bookings" indicator and can't submit a request. Existing
                bookings continue uninterrupted.
            </p>
            @if (_acceptingError is not null)
            {
                <p class="needlr-error" role="alert">@_acceptingError</p>
            }
            @if (_acceptingSaved)
            {
                <p class="needlr-info" role="status">Saved.</p>
            }
            <button type="button" class="needlr-btn primary"
                @onclick="SaveAcceptingAsync" disabled="@_savingAccepting">
                @(_savingAccepting ? "Saving…" : "Save")
            </button>
        </section>

        <section class="needlr-card">
            <h2>Stripe Connect</h2>
            <p class="needlr-aside">
                Per ADR-005 Needlr never holds funds — all deposits go directly to your
                Stripe Connect account. Customers can only book once your account is active.
            </p>

            @if (!string.IsNullOrEmpty(_connectAccountId))
            {
                <p>Account: <code>@_connectAccountId</code></p>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="needlr-error" role="alert">@_error</p>
            }
            <div class="needlr-action-row">
                <button type="button" class="needlr-btn primary" @onclick="StartOnboardingAsync" disabled="@_busy">
                    @(_busy ? "Working…" : "Start / continue Stripe onboarding")
                </button>
            </div>
        </section>

        <section class="needlr-card">
            <h2>Profile</h2>
            @if (_profile is null && _profileLoadError is null)
            {
                <p class="needlr-aside">Loading…</p>
            }
            else if (_profileLoadError is not null)
            {
                <p class="needlr-error" role="alert">@_profileLoadError</p>
            }
            else
            {
                <label class="needlr-stack">
                    <span>Bio</span>
                    <textarea @bind="_bio" rows="4" maxlength="2000" class="needlr-input"></textarea>
                    <small class="needlr-aside">@(_bio?.Length ?? 0) / 2000 characters</small>
                </label>
                <div class="needlr-row-2col">
                    <label class="needlr-stack">
                        <span>Years experience</span>
                        <input type="number" min="0" max="80" @bind="_yearsExperience" class="needlr-input" />
                    </label>
                    <label class="needlr-stack">
                        <span>Cancellation policy</span>
                        <select @bind="_cancellationPolicy" class="needlr-input">
                            <option value="Strict">Strict</option>
                            <option value="Standard">Standard</option>
                            <option value="Flexible">Flexible</option>
                        </select>
                    </label>
                </div>
                <div class="needlr-row-2col">
                    <label class="needlr-stack">
                        <span>Hourly rate (CAD)</span>
                        <input type="number" min="0" step="5" @bind="_hourlyRate" class="needlr-input" />
                        <small class="needlr-aside">Leave blank to hide.</small>
                    </label>
                    <label class="needlr-stack">
                        <span>Shop minimum (CAD)</span>
                        <input type="number" min="0" step="10" @bind="_shopMinimum" class="needlr-input" />
                        <small class="needlr-aside">Leave blank to hide.</small>
                    </label>
                </div>
                @if (_profileError is not null) { <p class="needlr-error" role="alert">@_profileError</p> }
                @if (_profileSaved) { <p class="needlr-info" role="status">Saved.</p> }
                <button type="button" class="needlr-btn primary"
                    @onclick="SaveProfileAsync" disabled="@_savingProfile">
                    @(_savingProfile ? "Saving…" : "Save profile")
                </button>
            }
        </section>

        <section class="needlr-card">
            <h2>iCal feed</h2>
            <p class="needlr-aside">
                Manage your subscription URL on the
                <a href="artist/availability">availability page</a>.
            </p>
        </section>
    }
</section>
</RequireAuth>

@code {
    private string? _connectAccountId;
    private bool _busy;
    private string? _error;

    private bool _accepting;
    private bool _savingAccepting;
    private bool _acceptingSaved;
    private string? _acceptingError;

    private ArtistDetailResponse? _profile;
    private string? _profileLoadError;
    private string _bio = string.Empty;
    private int _yearsExperience;
    private decimal? _hourlyRate;
    private decimal? _shopMinimum;
    private string _cancellationPolicy = "Standard";
    private bool _savingProfile;
    private bool _profileSaved;
    private string? _profileError;

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureHydratedAsync();
        if (!Auth.IsAuthenticated || Auth.Role != "Artist") return;

        // Both probes are independent and cheap — fan out.
        var acceptingTask = LoadAcceptingAsync();
        var profileTask = LoadProfileAsync();
        await Task.WhenAll(acceptingTask, profileTask);
    }

    private async Task LoadAcceptingAsync()
    {
        try
        {
            _accepting = await Api.GetMyAcceptingBookingsAsync();
        }
        catch (NeedlrApiException)
        {
            _accepting = true;
        }
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            _profile = await Api.GetMyArtistAsync();
            _bio = _profile.Bio;
            _yearsExperience = _profile.YearsExperience;
            _hourlyRate = _profile.HourlyRateCad;
            _shopMinimum = _profile.ShopMinimumCad;
            _cancellationPolicy = _profile.CancellationPolicy;
        }
        catch (NeedlrApiException ex) { _profileLoadError = ex.Message; }
    }

    private async Task SaveProfileAsync()
    {
        _savingProfile = true;
        _profileError = null;
        _profileSaved = false;
        try
        {
            await Api.UpdateMyArtistAsync(new UpdateArtistProfileRequest(
                _bio ?? string.Empty,
                _yearsExperience,
                _hourlyRate,
                _shopMinimum,
                _cancellationPolicy));
            _profileSaved = true;
        }
        catch (NeedlrApiException ex) { _profileError = ex.Message; }
        finally { _savingProfile = false; }
    }

    private async Task SaveAcceptingAsync()
    {
        _savingAccepting = true;
        _acceptingError = null;
        _acceptingSaved = false;
        try
        {
            await Api.SetMyAcceptingBookingsAsync(_accepting);
            _acceptingSaved = true;
        }
        catch (NeedlrApiException ex) { _acceptingError = ex.Message; }
        finally { _savingAccepting = false; }
    }

    private async Task StartOnboardingAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            // Idempotent — reuses the existing account if present.
            var account = await Api.CreateConnectAccountAsync();
            _connectAccountId = account.ConnectAccountId;

            var link = await Api.GenerateOnboardingLinkAsync(new OnboardingLinkRequest(
                ReturnUrl: $"{Nav.BaseUri}artist/profile?onboarding=return",
                RefreshUrl: $"{Nav.BaseUri}artist/profile?onboarding=refresh"));
            Nav.NavigateTo(link.Url, forceLoad: true);
        }
        catch (NeedlrApiException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
