@page "/artist/profile"
@inject INeedlrApi Api
@inject AuthState Auth
@inject NavigationManager Nav

<PageTitle>Account · Needlr</PageTitle>

<section class="needlr-profile-tools">
    @if (!Auth.IsAuthenticated || Auth.Role != "Artist")
    {
        <p class="needlr-aside">Artist sign-in required.</p>
    }
    else
    {
        <a class="needlr-link-back" href="artist">← Artist tools</a>
        <h1>Account</h1>
        <p class="needlr-sub">Signed in as <strong>@Auth.Email</strong> · Artist</p>

        <section class="needlr-card">
            <h2>Bookings</h2>
            <label class="needlr-toggle-row">
                <input type="checkbox" @bind="_accepting" />
                <span>Accepting new booking requests</span>
            </label>
            <p class="needlr-aside">
                When off, your profile stays visible on Needlr but new customers see a
                "not taking bookings" indicator and can't submit a request. Existing
                bookings continue uninterrupted.
            </p>
            @if (_acceptingError is not null)
            {
                <p class="needlr-error" role="alert">@_acceptingError</p>
            }
            @if (_acceptingSaved)
            {
                <p class="needlr-info" role="status">Saved.</p>
            }
            <button type="button" class="needlr-btn primary"
                @onclick="SaveAcceptingAsync" disabled="@_savingAccepting">
                @(_savingAccepting ? "Saving…" : "Save")
            </button>
        </section>

        <section class="needlr-card">
            <h2>Stripe Connect</h2>
            <p class="needlr-aside">
                Per ADR-005 Needlr never holds funds — all deposits go directly to your
                Stripe Connect account. Customers can only book once your account is active.
            </p>

            @if (!string.IsNullOrEmpty(_connectAccountId))
            {
                <p>Account: <code>@_connectAccountId</code></p>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="needlr-error" role="alert">@_error</p>
            }
            <div class="needlr-action-row">
                <button type="button" class="needlr-btn primary" @onclick="StartOnboardingAsync" disabled="@_busy">
                    @(_busy ? "Working…" : "Start / continue Stripe onboarding")
                </button>
            </div>
        </section>

        <section class="needlr-card">
            <h2>Profile editing</h2>
            <p class="needlr-aside">
                Bio, hourly rate, and shop minimum are managed via the API for v1. A
                dedicated FE editor lands when the <code>UpdateArtistProfile</code>
                endpoint ships (deferred Phase 23 item).
            </p>
        </section>

        <section class="needlr-card">
            <h2>iCal feed</h2>
            <p class="needlr-aside">
                Manage your subscription URL on the
                <a href="artist/availability">availability page</a>.
            </p>
        </section>
    }
</section>

@code {
    private string? _connectAccountId;
    private bool _busy;
    private string? _error;

    private bool _accepting;
    private bool _savingAccepting;
    private bool _acceptingSaved;
    private string? _acceptingError;

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureHydratedAsync();
        if (!Auth.IsAuthenticated || Auth.Role != "Artist") return;
        try
        {
            _accepting = await Api.GetMyAcceptingBookingsAsync();
        }
        catch (NeedlrApiException)
        {
            // Initial load failure is recoverable — the user can still toggle and save.
            _accepting = true;
        }
    }

    private async Task SaveAcceptingAsync()
    {
        _savingAccepting = true;
        _acceptingError = null;
        _acceptingSaved = false;
        try
        {
            await Api.SetMyAcceptingBookingsAsync(_accepting);
            _acceptingSaved = true;
        }
        catch (NeedlrApiException ex) { _acceptingError = ex.Message; }
        finally { _savingAccepting = false; }
    }

    private async Task StartOnboardingAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            // Idempotent — reuses the existing account if present.
            var account = await Api.CreateConnectAccountAsync();
            _connectAccountId = account.ConnectAccountId;

            var link = await Api.GenerateOnboardingLinkAsync(new OnboardingLinkRequest(
                ReturnUrl: $"{Nav.BaseUri}artist/profile?onboarding=return",
                RefreshUrl: $"{Nav.BaseUri}artist/profile?onboarding=refresh"));
            Nav.NavigateTo(link.Url, forceLoad: true);
        }
        catch (NeedlrApiException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
