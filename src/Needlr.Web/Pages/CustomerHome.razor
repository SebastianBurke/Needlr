@page "/me"
@inject INeedlrApi Api
@inject AuthState Auth
@inject IJSRuntime JS

<PageTitle>Account · Needlr</PageTitle>

<RequireAuth>
<section class="needlr-account-page">
        <h1>Account</h1>
        <p class="needlr-sub">Signed in as <strong>@(_profile?.Email ?? Auth.Email)</strong> · @Auth.Role</p>

        <section class="needlr-card">
            <h2>Profile</h2>
            @if (_profile is null && _profileLoadError is null)
            {
                <p class="needlr-aside">Loading…</p>
            }
            else if (_profileLoadError is not null)
            {
                <p class="needlr-error" role="alert">@_profileLoadError</p>
            }
            else
            {
                <label class="needlr-stack">
                    <span>Display name</span>
                    <input type="text" @bind="_displayName" maxlength="100" class="needlr-input" />
                </label>
                <label class="needlr-stack">
                    <span>Email</span>
                    <input type="email" value="@_profile!.Email" disabled readonly class="needlr-input" />
                    <small class="needlr-aside">Contact us to change your email address.</small>
                </label>
                @if (_saveError is not null)
                {
                    <p class="needlr-error" role="alert">@_saveError</p>
                }
                @if (_saved)
                {
                    <p class="needlr-info" role="status">Saved.</p>
                }
                <button type="button" class="needlr-btn primary"
                    @onclick="SaveProfileAsync" disabled="@(_saving || string.IsNullOrWhiteSpace(_displayName))">
                    @(_saving ? "Saving…" : "Save")
                </button>
            }
        </section>

        <section class="needlr-card">
            <h2>Notification preferences</h2>
            <p class="needlr-aside">Per-channel toggles for email + push.</p>
            <a href="me/preferences" class="needlr-btn">Manage preferences</a>
        </section>

        <section class="needlr-card">
            <h2>Bookings</h2>
            <a href="bookings" class="needlr-btn">View your bookings</a>
        </section>

        @if (_canPwaInstall)
        {
            <section class="needlr-card">
                <h2>Install Needlr</h2>
                <p class="needlr-aside">
                    Add Needlr to your home screen for faster access and Web Push support.
                </p>
                <button type="button" class="needlr-btn primary" @onclick="InstallPwaAsync">Install app</button>
                @if (!string.IsNullOrEmpty(_installResult))
                {
                    <p class="needlr-info" role="status">@_installResult</p>
                }
            </section>
        }

        <section class="needlr-card">
            <h2>Preferences</h2>
            <p class="needlr-aside">
                Home location, preferred styles, and search radius edit forms ship in a
                later release. For now your discovery view follows the map's viewport.
            </p>
        </section>
    }
</section>
</RequireAuth>

@code {
    private const string PwaScriptPath = "./js/pwaInterop.js";

    private IJSObjectReference? _pwaModule;
    private bool _canPwaInstall;
    private string? _installResult;

    private MyCustomerProfileResponse? _profile;
    private string _displayName = string.Empty;
    private bool _saving;
    private bool _saved;
    private string? _saveError;
    private string? _profileLoadError;

    protected override async Task OnInitializedAsync()
    {
        // Hydrate from localStorage before reading Auth.IsAuthenticated, otherwise hard
        // refreshes render the signed-out copy even when a valid token is in storage.
        await Auth.EnsureHydratedAsync();
        if (!Auth.IsAuthenticated || Auth.Role != "Customer") return;

        try
        {
            _profile = await Api.GetMyCustomerProfileAsync();
            _displayName = _profile.DisplayName;
        }
        catch (NeedlrApiException ex)
        {
            _profileLoadError = ex.Message;
        }
    }

    private async Task SaveProfileAsync()
    {
        _saving = true;
        _saveError = null;
        _saved = false;
        try
        {
            await Api.UpdateMyCustomerProfileAsync(new UpdateMyCustomerProfileRequest(_displayName));
            _saved = true;
            // Refresh the in-memory profile so the eyebrow + future renders pick up the new name.
            if (_profile is not null)
                _profile = _profile with { DisplayName = _displayName };
        }
        catch (NeedlrApiException ex) { _saveError = ex.Message; }
        finally { _saving = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !Auth.IsAuthenticated) return;

        try
        {
            _pwaModule = await JS.InvokeAsync<IJSObjectReference>("import", PwaScriptPath);
            _canPwaInstall = await _pwaModule.InvokeAsync<bool>("canPrompt");
            if (_canPwaInstall) StateHasChanged();
        }
        catch
        {
            // Browser doesn't support the install API or the module hasn't loaded — silently
            // skip; nothing to install.
        }
    }

    private async Task InstallPwaAsync()
    {
        if (_pwaModule is null) return;
        try
        {
            var outcome = await _pwaModule.InvokeAsync<string?>("prompt");
            _installResult = outcome switch
            {
                "accepted" => "Installed. Open Needlr from your home screen.",
                "dismissed" => "Not now. You can install any time from this page.",
                _ => "Install prompt unavailable in this browser."
            };
            _canPwaInstall = false;
        }
        catch (Exception ex)
        {
            _installResult = $"Install failed: {ex.Message}";
        }
    }
}
