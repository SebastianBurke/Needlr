@inherits LayoutComponentBase
@inject AuthState Auth
@inject INeedlrApi Api
@inject NavigationManager Nav
@implements IDisposable

<div class="needlr-shell">
    <header class="needlr-top">
        <div class="needlr-top-inner">
            <a href="" class="needlr-brand">Needlr</a>
            <nav class="needlr-top-nav">
                <NavLink href="" Match="NavLinkMatch.All" class="needlr-link">Discover</NavLink>
                @if (Auth.IsAuthenticated)
                {
                    <NavLink href="bookings" class="needlr-link">Bookings</NavLink>
                    @* Account dropdown: collapses Artist tools / Admin / Account / Sign out
                       so the top row stays compact regardless of role. Click anywhere outside
                       (the backdrop) closes it. *@
                    <div class="needlr-account">
                        <button type="button" class="needlr-account-trigger"
                            @onclick="() => _accountOpen = !_accountOpen"
                            aria-haspopup="menu"
                            aria-expanded="@_accountOpen.ToString().ToLower()"
                            title="Account">
                            <span class="needlr-account-avatar" aria-hidden="true">@AvatarInitial</span>
                        </button>
                        @if (_accountOpen)
                        {
                            <div class="needlr-account-backdrop" @onclick="() => _accountOpen = false"></div>
                            <div class="needlr-account-menu" role="menu" @onclick:stopPropagation="true">
                                <div class="needlr-account-header">
                                    <strong>@(Auth.Email ?? "Signed in")</strong>
                                    <small>@Auth.Role</small>
                                </div>
                                <NavLink href="me" class="needlr-account-item" @onclick="() => _accountOpen = false">Account</NavLink>
                                @if (Auth.Role == "Artist")
                                {
                                    <NavLink href="artist" class="needlr-account-item" @onclick="() => _accountOpen = false">Artist tools</NavLink>
                                    <NavLink href="artist/profile" class="needlr-account-item" @onclick="() => _accountOpen = false">Settings</NavLink>
                                }
                                @if (Auth.Role == "Admin")
                                {
                                    <NavLink href="admin" class="needlr-account-item" @onclick="() => _accountOpen = false">Admin</NavLink>
                                }
                                <button type="button" class="needlr-account-item needlr-account-signout"
                                    @onclick="SignOutAndCloseAsync">
                                    Sign out
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <NavLink href="login" class="needlr-link">Sign in</NavLink>
                    <NavLink href="register" class="needlr-link primary">Join</NavLink>
                }
            </nav>
        </div>
    </header>

    <main class="needlr-main">
        @Body
    </main>

    <footer class="needlr-footer">
        <span>Needlr</span>
        <span class="needlr-footer-sep">·</span>
        <NavLink href="v1" class="needlr-footer-link">v1</NavLink>
    </footer>

    @* Mobile bottom nav. Hidden on tablet+ via CSS. *@
    <nav class="needlr-bottom-nav">
        <NavLink href="" Match="NavLinkMatch.All" class="needlr-bottom-link">
            <span aria-hidden="true">🧭</span><span>Discover</span>
        </NavLink>
        @if (Auth.IsAuthenticated)
        {
            <NavLink href="bookings" class="needlr-bottom-link">
                <span aria-hidden="true">📅</span><span>Bookings</span>
            </NavLink>
            <NavLink href="me" class="needlr-bottom-link">
                <span aria-hidden="true">👤</span><span>Me</span>
            </NavLink>
        }
        else
        {
            <NavLink href="login" class="needlr-bottom-link">
                <span aria-hidden="true">🔑</span><span>Sign in</span>
            </NavLink>
        }
    </nav>
</div>

@code {
    private bool _accountOpen;

    private string AvatarInitial =>
        string.IsNullOrEmpty(Auth.Email)
            ? "•"
            : Auth.Email[..1].ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnAuthChanged;
        Auth.SignedOut += OnSignedOut;
        // Hydrate AuthState from localStorage before the first render so the header
        // renders signed-in state on hard refreshes / direct URL navs.
        await Auth.EnsureHydratedAsync();
    }

    private void OnAuthChanged() => InvokeAsync(StateHasChanged);

    /// <summary>
    /// Whenever the auth state transitions from authed to not-authed (Sign-out button,
    /// refresh-token failure, etc.), land the user on Discovery. This is the single
    /// redirect point for logout — page-level guards still cover direct nav to a protected
    /// page while not authenticated.
    /// </summary>
    private void OnSignedOut() => InvokeAsync(() => Nav.NavigateTo("/", forceLoad: false));

    private async Task SignOutAndCloseAsync()
    {
        _accountOpen = false;
        // Pass the API's logout delegate so the refresh token is revoked server-side
        // before the local clear. Best-effort: if the network call fails, AuthState still
        // clears local state and fires SignedOut so the user lands on Discovery.
        await Auth.SignOutAsync(Api.LogoutAsync);
    }

    public void Dispose()
    {
        Auth.Changed -= OnAuthChanged;
        Auth.SignedOut -= OnSignedOut;
    }
}
