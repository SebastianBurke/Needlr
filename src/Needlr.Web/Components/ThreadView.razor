@inject INeedlrApi Api
@inject AuthState Auth
@implements IDisposable

<section class="needlr-thread-view">
    @if (_loadError is not null)
    {
        <p class="needlr-error" role="alert">@_loadError</p>
    }
    else
    {
        @if (_thread is not null)
        {
            <div class="needlr-thread-status">
                <span class="needlr-badge @(_thread.Status == "Locked" ? "unverified" : "submitted")">
                    @_thread.Status
                </span>
                @if (_thread.LockedAt is { } lk)
                {
                    <small>Locked @lk.ToString("yyyy-MM-dd")</small>
                }
            </div>
        }

        <div class="needlr-message-list" @ref="_listEl">
            @if (_messages is null)
            {
                <p>Loading…</p>
            }
            else if (_messages.Items.Count == 0)
            {
                <p class="needlr-aside">No messages yet.</p>
            }
            else
            {
                @foreach (var m in _messages.Items)
                {
                    <article class="needlr-message @(IsMine(m) ? "mine" : "theirs") @(m.IsReportedFlag ? "reported" : "")">
                        <header>
                            <span class="needlr-msg-author">@(IsMine(m) ? "You" : "Them")</span>
                            <small>· @m.SentAt.ToString("HH:mm")</small>
                            @if (m.ReadAt is not null && IsMine(m))
                            {
                                <small class="needlr-read-receipt">· read</small>
                            }
                        </header>
                        <p>@m.Body</p>
                        @if (!IsMine(m) && _thread?.Status == "Active")
                        {
                            <button type="button" class="needlr-report" @onclick="() => OpenReport(m.Id)">Report</button>
                        }
                    </article>
                }
            }
        </div>

        @if (_thread?.Status == "Active")
        {
            <form class="needlr-composer" @onsubmit="SendAsync" @onsubmit:preventDefault>
                <textarea @bind="_compose" placeholder="Type a message…" rows="2" maxlength="5000"></textarea>
                @if (_sendError is not null)
                {
                    <p class="needlr-error" role="alert">@_sendError</p>
                }
                <button type="submit" class="needlr-btn primary" disabled="@(_sending || string.IsNullOrWhiteSpace(_compose))">
                    @(_sending ? "Sending…" : "Send")
                </button>
            </form>
        }
        else if (_thread is not null)
        {
            <p class="needlr-aside">This thread is locked. Existing messages remain visible; no new messages can be sent.</p>
        }
    }
</section>

@if (_reportingMessageId is { } rid)
{
    <ReportDialog MessageId="rid" OnDone="OnReportDone" />
}

@code {
    private const int PollIntervalSeconds = 30;

    /// <summary>
    /// The booking-scoped thread to render. The parent (BookingDetail) already has the
    /// ThreadResponse from <c>GetThreadByBookingAsync</c>, so passing it through saves a
    /// roundtrip and lets ThreadView focus solely on messages + composer state.
    /// </summary>
    [Parameter, EditorRequired] public ThreadResponse Thread { get; set; } = null!;

    private ThreadResponse? _thread;
    private MessagePageResponse? _messages;
    private string _compose = string.Empty;
    private bool _sending;
    private string? _sendError;
    private string? _loadError;
    private CancellationTokenSource? _polling;
    private ElementReference _listEl;
    private Guid? _reportingMessageId;
    private Guid? _lastLoadedThread;

    protected override async Task OnParametersSetAsync()
    {
        if (Thread.Id == _lastLoadedThread) return;
        _lastLoadedThread = Thread.Id;
        _thread = Thread;
        StopPolling();
        if (Thread.Id == Guid.Empty) return;
        await LoadAsync();
        StartPolling();
    }

    private async Task LoadAsync()
    {
        _loadError = null;
        try
        {
            _messages = await Api.ListThreadMessagesAsync(Thread.Id, page: 1, pageSize: 200);
            await MarkOtherPartyMessagesReadAsync();
        }
        catch (NeedlrApiException ex)
        {
            _loadError = ex.Message;
        }
    }

    private async Task MarkOtherPartyMessagesReadAsync()
    {
        if (_messages is null || Auth.UserId is not { } me) return;
        foreach (var m in _messages.Items)
        {
            if (m.SenderId != me && m.ReadAt is null)
            {
                try { await Api.MarkMessageReadAsync(m.Id); }
                catch (NeedlrApiException) { /* best-effort */ }
            }
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_compose)) return;
        _sending = true;
        _sendError = null;
        try
        {
            var body = _compose.Trim();
            await Api.SendMessageAsync(Thread.Id, new SendMessageRequest(body));
            _compose = string.Empty;
            await LoadAsync();
        }
        catch (NeedlrApiException ex)
        {
            _sendError = ex.Message;
        }
        finally
        {
            _sending = false;
        }
    }

    private void StartPolling()
    {
        StopPolling();
        _polling = new CancellationTokenSource();
        _ = PollLoopAsync(_polling.Token);
    }

    private async Task PollLoopAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(PollIntervalSeconds), cancellationToken);
                if (cancellationToken.IsCancellationRequested) return;
                await InvokeAsync(async () =>
                {
                    await LoadAsync();
                    StateHasChanged();
                });
            }
            catch (TaskCanceledException) { return; }
            catch { /* keep the loop alive on transient errors */ }
        }
    }

    private void StopPolling()
    {
        _polling?.Cancel();
        _polling?.Dispose();
        _polling = null;
    }

    private bool IsMine(MessageResponse m) => Auth.UserId == m.SenderId;

    private void OpenReport(Guid messageId) => _reportingMessageId = messageId;

    private async Task OnReportDone()
    {
        _reportingMessageId = null;
        await LoadAsync();
    }

    public void Dispose() => StopPolling();
}
